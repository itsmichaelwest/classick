# Rust — matches workspace target/ at repo root AND any per-crate target/
# (the daemon-integration tests poke crates/classick/target/test-tmp/).
# Trailing-slash-only pattern matches at any depth.
target/

# libgpod binaries are platform-specific and large. `**/` makes the patterns
# depth-agnostic so they match `vendor/` under any workspace member, current
# or future.
**/vendor/libgpod/bin/*.dll
**/vendor/libgpod/bin/*.pdb

# gdk-pixbuf loader plugin DLLs (same reasoning as above; the loaders.cache
# manifest IS committed since it's small text and documents what was vendored)
**/vendor/libgpod/pixbuf-loaders/*.dll

# lib.exe /def byproducts
**/vendor/libgpod/lib/*.exp

# Refalac binaries (opt-in encoder; user obtains from qaac releases).
# See docs/superpowers/specs/2026-05-23-phase-3-addendum.md for install instructions.
**/vendor/refalac/

# Build artifacts
*.exe
*.pdb

# Editor
.vscode/
.idea/

# OS
Thumbs.db
.DS_Store

# Project state (manifest lives in %APPDATA%, but be safe)
/manifest.json
.superpowers/

# Daemon runtime artifacts
/daemon-stdout.log
/daemon-stderr.log

# LOCAL macOS libgpod pkg-config env (machine-specific)
.cargo/config.toml
.superpowers/

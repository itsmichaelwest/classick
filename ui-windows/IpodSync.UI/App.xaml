<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="IpodSync_UI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:IpodSync_UI"
    xmlns:tb="using:H.NotifyIcon">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>

            <!--
                Quit command surfaced through the tray menu. Exposed as an
                Application resource so TrayIconController can bind its
                ExecuteRequested handler at startup.
            -->
            <XamlUICommand x:Key="QuitCommand" Label="Quit" Description="Quit" />

            <!--
                Sync Now command surfaced through the tray menu. M3 wires
                this to a TriggerSync("manual") IPC call against the daemon.
            -->
            <XamlUICommand x:Key="SyncNowCommand" Label="Sync Now" Description="Sync Now" />

            <!--
                Settings command surfaced through the tray context menu.
                M4 wires this to opening the SettingsWindow.
            -->
            <XamlUICommand x:Key="SettingsCommand" Label="Settings" Description="Settings" />

            <!--
                Left-click on the tray icon opens the status popover.
                Bound to TaskbarIcon.LeftClickCommand below.
            -->
            <XamlUICommand x:Key="OpenPopoverCommand" Label="Open" Description="Open status popover" />

            <!--
                Tray icon defined here (NOT in C#) so it inherits
                Application-resource lifetime. That lifetime anchor is what
                keeps the process alive after the last window closes in
                tray-only mode. Pattern lifted from the H.NotifyIcon
                "Windowless" sample.

                ContextMenuMode="SecondWindow" avoids the process-leak that
                "PopupMenu" mode causes on exit (H.NotifyIcon issue #66).
            -->
            <!--
                IconSource is intentionally NOT set here. The PNG filenames
                (e.g. Default_Dark_32.png) trip the MRT resource indexer
                because it parses the trailing `_<n>` as a malformed qualifier
                (PRI249 warning at build time). Resolving `ms-appx:///…` at
                runtime then throws ERROR_INSUFFICIENT_BUFFER inside WinRT
                marshalling. TrayIconController applies the correct icon via
                an absolute file path during Initialize(), before ForceCreate.
            -->
            <tb:TaskbarIcon
                x:Key="TrayIcon"
                Visibility="Visible"
                ToolTipText="ipod-sync · idle"
                ContextMenuMode="SecondWindow"
                NoLeftClickDelay="True"
                LeftClickCommand="{StaticResource OpenPopoverCommand}">
                <tb:TaskbarIcon.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Command="{StaticResource SyncNowCommand}" />
                        <MenuFlyoutItem Command="{StaticResource SettingsCommand}" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Command="{StaticResource QuitCommand}" />
                    </MenuFlyout>
                </tb:TaskbarIcon.ContextFlyout>
            </tb:TaskbarIcon>
        </ResourceDictionary>
    </Application.Resources>
</Application>

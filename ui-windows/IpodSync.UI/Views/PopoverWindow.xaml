<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="IpodSync_UI.Views.PopoverWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:IpodSync_UI.ViewModels"
    Title="iPod Status">
    <!--
        Root size lives here (not in code) so designers can tweak the
        popover footprint without recompiling. PopoverWindow.cs measures
        this Grid before first Activate() and resizes the AppWindow to
        match, so the window appears already at the right size — no
        centre-of-screen flash and no resize jump.
    -->
    <Grid x:Name="PopoverRoot" Width="360" Height="192">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="48" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1"
                    Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <!--
                    Device graphic. Drop an SVG at Assets/ipod.svg (or any
                    raster format) and the Image will pick it up via the
                    csproj Content include. WinUI 3 routes .svg URIs through
                    SvgImageSource automatically, so the image scales
                    cleanly at every DPI.
                -->
                <Image Source="ms-appx:///Assets/ipod.svg"
                       Width="30"
                       Height="48"
                       Stretch="Uniform" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.DeviceLabel, Mode=OneWay}"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock Text="{x:Bind ViewModel.LastSyncedLabel, Mode=OneWay}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <!--
                Storage block. Visible only when idle AND we have
                storage info from the daemon. Collapses during sync so
                the progress block below takes its place — same vertical
                footprint, no popover resize on state change.
            -->
            <StackPanel Visibility="{x:Bind ViewModel.ShowStorage, Mode=OneWay}">
                <Grid MinHeight="32">
                    <ProgressBar Value="{x:Bind ViewModel.StorageProgressValue, Mode=OneWay}"
                                 Minimum="0"
                                 Maximum="100" />
                </Grid>
                <Grid>
                    <TextBlock Text="{x:Bind ViewModel.StorageUsedLabel, Mode=OneWay}"
                               HorizontalAlignment="Left"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock Text="{x:Bind ViewModel.StorageFreeLabel, Mode=OneWay}"
                               HorizontalAlignment="Right"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Grid>
            </StackPanel>

            <!--
                Live sync-progress block. Visible during a sync; driven
                by IpcEvent forwards from the sync subprocess via the
                DaemonEventRouter. ProgressBar Maximum binds to total so
                Value can use raw track index — Indeterminate kicks in
                before the first TrackStart (Maximum=0).
            -->
            <StackPanel Visibility="{x:Bind ViewModel.Syncing, Mode=OneWay}">
                <Grid MinHeight="32">
                    <ProgressBar Value="{x:Bind ViewModel.ProgressCurrent, Mode=OneWay}"
                                 Minimum="0"
                                 Maximum="{x:Bind ViewModel.ProgressTotal, Mode=OneWay}"
                                 IsIndeterminate="{x:Bind ViewModel.NoProgressYet, Mode=OneWay}" />
                </Grid>
                <Grid>
                    <TextBlock Text="{x:Bind ViewModel.CurrentTrackLabel, Mode=OneWay}"
                               HorizontalAlignment="Left"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="220"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock Text="{x:Bind ViewModel.ProgressLabel, Mode=OneWay}"
                               HorizontalAlignment="Right"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Grid>
            </StackPanel>
        </StackPanel>

        <!--
            Footer actions. NOTE: Grid.Row="1" — earlier this said "2"
            which silently clamped to the last defined row; harmless but
            misleading when reading the XAML.
        -->
        <Grid Grid.Row="1" Padding="8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Click="OnSyncNow"
                    MinWidth="120"
                    Visibility="{x:Bind ViewModel.NotSyncing, Mode=OneWay}"
                    Style="{ThemeResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE895;" FontSize="16" />
                    <TextBlock Text="Sync now" />
                </StackPanel>
            </Button>
            <Button Grid.Column="0"
                    Click="OnCancelSync"
                    MinWidth="120"
                    Visibility="{x:Bind ViewModel.Syncing, Mode=OneWay}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE711;" FontSize="16" />
                    <TextBlock Text="Stop sync" />
                </StackPanel>
            </Button>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="2">
                <Button Click="OnOpenSource"
                        ToolTipService.ToolTip="Open source folder"
                        Style="{StaticResource SubtleButtonStyle}"
                        Padding="10"
                        BorderThickness="0">
                    <FontIcon Glyph="&#xE838;" FontSize="16" />
                </Button>
                <Button ToolTipService.ToolTip="Eject iPod"
                        Style="{StaticResource SubtleButtonStyle}"
                        Padding="10"
                        BorderThickness="0">
                    <FontIcon Glyph="&#xF847;" FontSize="16" />
                </Button>
                <Button Click="OnOpenSettings"
                        ToolTipService.ToolTip="Settings"
                        Style="{StaticResource SubtleButtonStyle}"
                        Padding="10"
                        BorderThickness="0">
                    <FontIcon Glyph="&#xE713;" FontSize="16" />
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>

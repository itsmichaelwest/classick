<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="IpodSync_UI.Views.WizardWelcomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="16"
                MaxWidth="400">
        <Image Source="ms-appx:///Assets/ipod.svg"
               Width="96" Height="96"
               HorizontalAlignment="Center" />
        <TextBlock Text="Welcome to ipod-sync"
                   Style="{ThemeResource SubtitleTextBlockStyle}"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,0" />
        <TextBlock TextWrapping="Wrap"
                   TextAlignment="Center"
                   Text="ipod-sync lets you sync your iPod from a folder of music on your PC. Any file format, conversion is handled automatically." />
        <TextBlock TextWrapping="Wrap"
                   TextAlignment="Center"
                   Text="To begin, you'll need to choose your music folder, device, and basic sync options. You can always change these settings later." />
    </StackPanel>
</Page>

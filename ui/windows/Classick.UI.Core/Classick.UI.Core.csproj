<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!--
      Plain net10.0 (no -windows TFM, no WinAppSDK). This project hosts the
      pure System.* IPC plumbing (Ipc/IpcEvent.cs, IpcCommand.cs, CoreProcess.cs)
      so it can be unit-tested from a vstest host without tripping the WinUI 3
      runtime auto-initializer. The WinUI app project (Classick.UI) references
      this assembly and consumes the types directly under the Classick_UI.Ipc
      namespace.
    -->
    <TargetFramework>net10.0</TargetFramework>
    <!--
      Match Classick.UI's Platforms (x64;ARM64) so the .slnx auto-generated
      solution configurations have a 1:1 project mapping. Without this VS
      reports "solution specifies a project configuration that does not
      exist" because the slnx tries to build this lib at x64/ARM64 but
      the default AnyCPU project has no such configuration. Class libraries
      are IL-only so per-platform output dirs are harmless.
    -->
    <Platforms>x64;ARM64</Platforms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Classick_UI</RootNamespace>
  </PropertyGroup>

</Project>

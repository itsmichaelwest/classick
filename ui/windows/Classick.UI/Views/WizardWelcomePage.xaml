<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Classick_UI.Views.WizardWelcomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="16"
                MaxWidth="400">
        <!--
          Source from targetsize-512 — the largest authored variant — and let
          WinUI downscale to 96 DIPs. Pure downscale at every supported DPI
          (96→384 actual pixels at 400%, well under 512). AppList.scale-* tops
          out at 176 px so it would upscale above 100% DPI.
        -->
        <Image Source="ms-appx:///Assets/AppList.targetsize-512.png"
               Width="96" Height="96"
               HorizontalAlignment="Center" />
        <TextBlock Text="Welcome to classick"
                   Style="{ThemeResource SubtitleTextBlockStyle}"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,0" />
        <TextBlock TextWrapping="Wrap"
                   TextAlignment="Center"
                   Text="classick lets you sync your iPod from a folder of music on your PC. Any file format, conversion is handled automatically." />
        <TextBlock TextWrapping="Wrap"
                   TextAlignment="Center"
                   Text="To begin, you'll need to choose your music folder, device, and basic sync options. You can always change these settings later." />
    </StackPanel>
</Page>

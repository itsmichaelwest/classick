<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Classick_UI.Views.SettingsGeneralPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls">
    <!--
        General settings page. Mirrors the Figma — page-title "Settings",
        then section labels (General, About) with SettingsCard /
        SettingsExpander rows. Edits auto-save through the parent
        ViewModel's debounced SaveAsync; there is no Save button.

        Content width matches the Figma column width (392 DIP). Page
        padding is 24 left/right per design.
    -->
    <ScrollViewer>
        <StackPanel Padding="24" Spacing="20" HorizontalAlignment="Stretch">
            <TextBlock Text="Settings" Style="{ThemeResource TitleTextBlockStyle}" />

            <!-- ============ General section ============ -->
            <TextBlock Text="General" Style="{ThemeResource BodyStrongTextBlockStyle}" />
            <StackPanel Spacing="4">
                <tk:SettingsCard Header="Music folder"
                                 Description="{x:Bind ViewModel.General.SourcePath, Mode=OneWay}">
                    <tk:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE8B7;" />
                    </tk:SettingsCard.HeaderIcon>
                    <Button Content="Change…" Click="OnPickSource" />
                </tk:SettingsCard>

                <tk:SettingsExpander Header="Apply policy"
                                     Description="{x:Bind ViewModel.General.SyncModeSummary, Mode=OneWay}">
                    <tk:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE895;" />
                    </tk:SettingsExpander.HeaderIcon>
                    <tk:SettingsExpander.Items>
                        <tk:SettingsCard ContentAlignment="Left">
                            <StackPanel Spacing="8" Margin="0,0,0,6">
                                <RadioButton GroupName="SyncMode"
                                             Content="Apply automatically"
                                             IsChecked="{x:Bind IsAutomatic, Mode=TwoWay}" />
                                <TextBlock Text="Apply planned library changes without asking for review"
                                           Margin="28,-12,0,8"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <RadioButton GroupName="SyncMode"
                                             Content="Review changes"
                                             IsChecked="{x:Bind IsManual, Mode=TwoWay}" />
                                <TextBlock Text="Show the change plan before Classick writes to the iPod"
                                           Margin="28,-12,0,0"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </tk:SettingsCard>
                    </tk:SettingsExpander.Items>
                </tk:SettingsExpander>

                <tk:SettingsCard Header="Sync frequency"
                                 Description="Run a periodic sync even if the iPod stays plugged in">
                    <tk:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE823;" />
                    </tk:SettingsCard.HeaderIcon>
                    <!--
                        Tag must be authored as <x:Int32> so the
                        SelectedValuePath=Tag comparison matches the int
                        VM property. A bare Tag="30" is a string, and
                        string vs int never matches → dropdown renders
                        empty even when the underlying value is set.
                    -->
                    <ComboBox SelectedValue="{x:Bind ViewModel.General.ScheduleMinutes, Mode=TwoWay}"
                              SelectedValuePath="Tag"
                              MinWidth="160">
                        <ComboBoxItem Content="Only on plug-in">
                            <ComboBoxItem.Tag><x:Int32>0</x:Int32></ComboBoxItem.Tag>
                        </ComboBoxItem>
                        <ComboBoxItem Content="Every 15 minutes">
                            <ComboBoxItem.Tag><x:Int32>15</x:Int32></ComboBoxItem.Tag>
                        </ComboBoxItem>
                        <ComboBoxItem Content="Every 30 minutes">
                            <ComboBoxItem.Tag><x:Int32>30</x:Int32></ComboBoxItem.Tag>
                        </ComboBoxItem>
                        <ComboBoxItem Content="Every hour">
                            <ComboBoxItem.Tag><x:Int32>60</x:Int32></ComboBoxItem.Tag>
                        </ComboBoxItem>
                        <ComboBoxItem Content="Every 4 hours">
                            <ComboBoxItem.Tag><x:Int32>240</x:Int32></ComboBoxItem.Tag>
                        </ComboBoxItem>
                        <ComboBoxItem Content="Once a day">
                            <ComboBoxItem.Tag><x:Int32>1440</x:Int32></ComboBoxItem.Tag>
                        </ComboBoxItem>
                    </ComboBox>
                </tk:SettingsCard>

                <tk:SettingsCard Header="Launch classick on startup"
                                 Description="Start this app automatically when you sign in to Windows">
                    <tk:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE7E8;" />
                    </tk:SettingsCard.HeaderIcon>
                    <ToggleSwitch IsOn="{x:Bind ViewModel.General.LaunchOnStartup, Mode=TwoWay}" />
                </tk:SettingsCard>

                <tk:SettingsCard Header="{x:Bind ViewModel.General.SelectedDeviceName, Mode=OneWay}"
                                 Description="{x:Bind ViewModel.General.SelectedDeviceSummary, Mode=OneWay}">
                    <tk:SettingsCard.HeaderIcon>
                        <ImageIcon Source="ms-appx:///Assets/ipod-generic.svg" />
                    </tk:SettingsCard.HeaderIcon>
                </tk:SettingsCard>

                <tk:SettingsCard Header="Sync this iPod automatically"
                                 Description="This setting belongs to the selected iPod and remains editable while disconnected">
                    <ToggleSwitch IsOn="{x:Bind ViewModel.General.AutoSync, Mode=TwoWay}"
                                  IsEnabled="{x:Bind ViewModel.General.CanEditDeviceSettings, Mode=OneWay}" />
                </tk:SettingsCard>

                <tk:SettingsCard Header="Rockbox compatibility"
                                 Description="Maintain the additional files required when this iPod uses Rockbox">
                    <ToggleSwitch IsOn="{x:Bind ViewModel.General.RockboxCompat, Mode=TwoWay}"
                                  IsEnabled="{x:Bind ViewModel.General.CanEditDeviceSettings, Mode=OneWay}" />
                </tk:SettingsCard>

                <tk:SettingsCard Header="Device settings"
                                 Description="{x:Bind ViewModel.General.DeliveryStatus, Mode=OneWay}" />

                <tk:SettingsCard Header="Music selection mode"
                                 Description="{x:Bind ViewModel.General.SelectionSummary, Mode=OneWay}">
                    <StackPanel Spacing="4" IsEnabled="{x:Bind ViewModel.General.CanEditSelection, Mode=OneWay}">
                        <RadioButton GroupName="SelectionMode" Content="All music"
                                     IsChecked="{x:Bind IsSelectionAll, Mode=TwoWay}" />
                        <RadioButton GroupName="SelectionMode" Content="Only matching selection rules"
                                     IsChecked="{x:Bind IsSelectionInclude, Mode=TwoWay}" />
                        <RadioButton GroupName="SelectionMode" Content="Everything except matching selection rules"
                                     IsChecked="{x:Bind IsSelectionExclude, Mode=TwoWay}" />
                    </StackPanel>
                </tk:SettingsCard>

                <tk:SettingsCard Header="Playlist subscriptions"
                                 Description="{x:Bind ViewModel.General.SubscriptionsSummary, Mode=OneWay}">
                    <TextBox Text="{x:Bind ViewModel.General.PlaylistSubscriptionsText, Mode=TwoWay}"
                             PlaceholderText="playlist-slug, another-playlist"
                             IsEnabled="{x:Bind ViewModel.General.CanEditSubscriptions, Mode=OneWay}"
                             MinWidth="220" />
                </tk:SettingsCard>

                <tk:SettingsCard Header="Last sync"
                                 Description="{x:Bind ViewModel.General.LastSyncStatus, Mode=OneWay}" />

                <tk:SettingsCard Header="Device actions"
                                 Description="Sync now or explicitly replace this iPod's library from the selected Classick library">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Sync now" Click="OnSyncNow" />
                        <Button Content="Replace library…" Click="OnReplaceLibrary" />
                    </StackPanel>
                </tk:SettingsCard>

                <tk:SettingsCard Header="Remove this iPod"
                                 Description="Forget and re-run the wizard to pair a different iPod">
                    <tk:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE74D;" />
                    </tk:SettingsCard.HeaderIcon>
                    <Button Content="Remove…" Click="OnRemoveIpod" />
                </tk:SettingsCard>
            </StackPanel>

            <TextBlock Text="{x:Bind ViewModel.General.SaveError, Mode=OneWay}"
                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                       TextWrapping="Wrap" />

            <!-- ============ iTunes interop notice ============ -->
            <TextBlock Text="Apple software" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,12,0,0" />
            <tk:SettingsCard Header="Finder, Apple Devices, and iTunes remain supported"
                             Description="Classick uses the Apple-initialized iPod database. Keep other device managers closed only while Classick is actively writing to the iPod.">
                <tk:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE7BA;" />
                </tk:SettingsCard.HeaderIcon>
            </tk:SettingsCard>

            <!-- ============ About section ============ -->
            <TextBlock Text="About" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,12,0,0" />
            <tk:SettingsCard Header="{x:Bind ViewModel.About.AppName, Mode=OneWay}"
                             Description="{x:Bind ViewModel.About.VersionLabel, Mode=OneWay}">
                <tk:SettingsCard.HeaderIcon>
                    <ImageIcon Source="ms-appx:///Assets/ipod-generic.svg" />
                </tk:SettingsCard.HeaderIcon>
                <Button Click="OnShowLogFolder">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE838;" FontSize="14" />
                        <TextBlock Text="Log folder" />
                    </StackPanel>
                </Button>
            </tk:SettingsCard>
        </StackPanel>
    </ScrollViewer>
</Page>

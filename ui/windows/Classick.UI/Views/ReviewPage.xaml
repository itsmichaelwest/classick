<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Classick_UI.Views.ReviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Classick_UI.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="24" MaxWidth="640" HorizontalAlignment="Center">

            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock Text="Review action plan" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="Confirm before any changes are written to the iPod." Opacity="0.7" />
            </StackPanel>

            <!-- Paths -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="100,*">
                        <TextBlock Grid.Column="0" Text="Source" Opacity="0.7" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Source, Mode=OneWay}" TextWrapping="Wrap" />
                    </Grid>
                    <Grid ColumnDefinitions="100,*">
                        <TextBlock Grid.Column="0" Text="iPod" Opacity="0.7" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Ipod, Mode=OneWay}" />
                    </Grid>
                    <Grid ColumnDefinitions="100,*">
                        <TextBlock Grid.Column="0" Text="Manifest" Opacity="0.7" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Manifest, Mode=OneWay}" TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Action plan -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Text="Action plan" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <Grid ColumnDefinitions="160,*">
                        <TextBlock Grid.Column="0" Text="Add" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Add, Mode=OneWay}" />
                    </Grid>
                    <Grid ColumnDefinitions="160,*">
                        <TextBlock Grid.Column="0" Text="Modify" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Modify, Mode=OneWay}" />
                    </Grid>
                    <Grid ColumnDefinitions="160,*">
                        <TextBlock Grid.Column="0" Text="Metadata only" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.MetadataOnly, Mode=OneWay}" />
                    </Grid>
                    <Grid ColumnDefinitions="160,*">
                        <TextBlock Grid.Column="0" Text="Remove (effective)" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.EffectiveRemove, Mode=OneWay}" />
                    </Grid>
                    <Grid ColumnDefinitions="160,*">
                        <TextBlock Grid.Column="0" Text="Unchanged" Opacity="0.5" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Unchanged, Mode=OneWay}" Opacity="0.5" />
                    </Grid>
                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8" />
                    <Grid ColumnDefinitions="160,*">
                        <TextBlock Grid.Column="0" Text="Total to apply" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.TotalToApply, Mode=OneWay}" FontWeight="SemiBold" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- No-delete toggle -->
            <ToggleSwitch
                Header="--no-delete"
                OnContent="Skip Remove actions"
                OffContent="Apply Remove actions"
                IsOn="{x:Bind ViewModel.NoDelete, Mode=TwoWay}" />

            <!-- Decision buttons -->
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <Button Content="Quit" Command="{x:Bind ViewModel.QuitCommand}" />
                <Button Content="Dry run" Command="{x:Bind ViewModel.DryRunCommand}" />
                <Button Content="Apply" Style="{StaticResource AccentButtonStyle}" Command="{x:Bind ViewModel.ApplyCommand}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>

<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Classick_UI.Views.WizardDonePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="16"
                MaxWidth="400">
        <TextBlock Text="🎉"
                   FontSize="72"
                   HorizontalAlignment="Center" />
        <TextBlock Text="You're all set!"
                   Style="{ThemeResource SubtitleTextBlockStyle}"
                   HorizontalAlignment="Center" />
        <TextBlock TextWrapping="Wrap"
                   TextAlignment="Center"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Text="classick will now start syncing your music. Since this is the first time, the process may take several minutes or even a few hours. You can always monitor progress from the tray icon." />

        <Border Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                BorderBrush="{ThemeResource SystemFillColorCautionBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12,10"
                Margin="0,8,0,0">
            <StackPanel Spacing="4">
                <TextBlock Text="Heads-up about iTunes"
                           FontWeight="SemiBold"
                           FontSize="13" />
                <TextBlock TextWrapping="Wrap"
                           FontSize="12"
                           Text="Once classick has touched your iPod, iTunes will refuse to recognize it (&quot;cannot read the contents&quot;) and offer to Restore. Don't click Restore — your iPod is fine, iTunes just doesn't recognize this DB format. Close iTunes and keep using classick." />
            </StackPanel>
        </Border>
    </StackPanel>
</Page>

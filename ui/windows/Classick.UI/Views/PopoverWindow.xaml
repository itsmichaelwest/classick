<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="Classick_UI.Views.PopoverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Classick_UI.ViewModels"
        Title="iPod Status">
    <!--
        Root grid stretches to fill the entire window client. The
        canonical popover size (360×192 DIP) lives as a constant in
        PopoverWindow.xaml.cs and is applied via AppWindow.ResizeClient
        before first Activate(), so the window appears already at the
        right size — no centre-of-screen flash and no resize jump.
        
        Why stretch instead of explicit Width/Height: WinAppSDK 2.x
        reserves an invisible window-header drag-area band inside the
        client rect even when hasTitleBar=false. With a fixed-size
        Grid, that band peeks out around the Grid as dark chrome bands
        top + bottom. Stretching paints the Grid edge-to-edge so the
        backdrop never shows around the content.
        
        The Grid hosts two mutually-exclusive layouts switched by
        IpodConnected: the normal connected layout (device row +
        storage + footer) and the empty state (centered icon + "No
        iPod connected" caption + footer with just Settings).
    -->
    <Grid x:Name="PopoverRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="48" />
        </Grid.RowDefinitions>

        <!--
            =================== CONTENT AREA ========================
            Holds both layouts so they share the same background +
            bottom border. Children are mutually exclusive via
            ShowConnectedContent / ShowEmptyState, swapped on the
            daemon's IpodConnected signal.
        -->
        <Grid Grid.Row="0"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">

            <!--
                Connected layout — device row, storage bar, and (during
                sync) progress block.
            -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{x:Bind ViewModel.ShowConnectedContent, Mode=OneWay}">
            <StackPanel Padding="16"
                        Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Image Width="30"
                           Height="44"
                           Source="{x:Bind ViewModel.DeviceArtworkUri, Mode=OneWay}"
                           AutomationProperties.Name="{x:Bind ViewModel.DeviceArtworkDescription, Mode=OneWay}"
                           Stretch="Uniform" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.DeviceLabel, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="{x:Bind ViewModel.DeviceHardwareSummary, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.DeviceHardwareProvenance, Mode=OneWay}"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.DeviceReadinessText, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.LastSyncedLabel, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>

                <InfoBar IsOpen="{x:Bind ViewModel.ShowDeviceGuidance, Mode=OneWay}"
                         IsClosable="False"
                         Severity="Informational"
                         Message="{x:Bind ViewModel.DeviceGuidance, Mode=OneWay}" />

                <!--
                    Storage block. Always rendered when idle so the
                    popover footprint matches the Figma regardless of
                    whether the daemon has reported storage yet —
                    placeholders kick in when HasStorage is false.
                -->
                <StackPanel Visibility="{x:Bind ViewModel.NotSyncing, Mode=OneWay}">
                    <Grid MinHeight="32">
                        <ProgressBar Minimum="0"
                                     Maximum="100"
                                     IsIndeterminate="False"
                                     Value="{x:Bind ViewModel.StorageProgressValue, Mode=OneWay}" />
                    </Grid>
                    <Grid>
                        <TextBlock HorizontalAlignment="Left"
                                   Text="{x:Bind ViewModel.StorageUsedDisplay, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBlock HorizontalAlignment="Right"
                                   Text="{x:Bind ViewModel.StorageFreeDisplay, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>
                </StackPanel>

                <!--
                    Live sync-progress block. Visible during a sync;
                    driven by IpcEvent forwards from the sync subprocess
                    via the DaemonEventRouter. ProgressBar Maximum binds
                    to total so Value can use raw track index —
                    Indeterminate kicks in before the first TrackStart
                    (Maximum=0).
                -->
                <StackPanel Visibility="{x:Bind ViewModel.Syncing, Mode=OneWay}">
                    <Grid MinHeight="32">
                        <ProgressBar Minimum="0"
                                     Maximum="{x:Bind ViewModel.ProgressTotal, Mode=OneWay}"
                                     IsIndeterminate="{x:Bind ViewModel.NoProgressYet, Mode=OneWay}"
                                     Value="{x:Bind ViewModel.ProgressCurrent, Mode=OneWay}" />
                    </Grid>
                    <Grid>
                        <TextBlock HorizontalAlignment="Left"
                                   Text="{x:Bind ViewModel.ProgressCaption, Mode=OneWay}"
                                   ToolTipService.ToolTip="{x:Bind ViewModel.CurrentTrackLabel, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBlock HorizontalAlignment="Right"
                                   Text="{x:Bind ViewModel.EtaLabel, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>
                </StackPanel>
            </StackPanel>
            </ScrollViewer>

            <!--
                Empty state — "No iPod connected" centered hero, shown
                when the daemon reports IpodConnected = false.
            -->
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12"
                        Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay}">
                <Image Width="30"
                       Height="44"
                       HorizontalAlignment="Center"
                       Source="ms-appx:///Assets/ipod-generic.svg"
                       Stretch="Uniform" />
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock HorizontalAlignment="Center"
                               Text="{x:Bind ViewModel.EmptyStateTitle, Mode=OneWay}"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock HorizontalAlignment="Center"
                               Text="{x:Bind ViewModel.EmptyStateSubtitle, Mode=OneWay}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Margin="8"
                        VerticalAlignment="Center"
                        Visibility="{x:Bind ViewModel.ShowSourceRecovery, Mode=OneWay}">
                <InfoBar IsOpen="{x:Bind ViewModel.SourceAttentionVisible, Mode=OneWay}"
                         IsClosable="False"
                         Severity="Warning"
                         Title="{x:Bind ViewModel.SourceAttentionTitle, Mode=OneWay}"
                         Message="{x:Bind ViewModel.SourceAttentionMessage, Mode=OneWay}">
                    <InfoBar.ActionButton>
                        <Button Content="Connect"
                                IsEnabled="{x:Bind ViewModel.SourceRetryAvailable, Mode=OneWay}"
                                Click="OnConnectSource" />
                    </InfoBar.ActionButton>
                </InfoBar>
                <InfoBar IsOpen="{x:Bind ViewModel.SourceRemounting, Mode=OneWay}"
                         IsClosable="False"
                         Severity="Informational"
                         Title="Reconnecting to music share…">
                    <InfoBar.Content>
                        <ProgressRing Width="20"
                                      Height="20"
                                      IsActive="True" />
                    </InfoBar.Content>
                </InfoBar>
            </StackPanel>
        </Grid>

        <!--
            Footer. Connected state: Sync now / Stop sync on the left,
            Eject + Settings on the right. Empty state: "Looking for
            iPod on USB…" caption on the left, only Settings on the
            right (Sync now / Eject would be no-ops without a device).
            Hidden entirely when a prompt overlay is active — its own
            option buttons are the only meaningful actions then.
        -->
        <Grid Grid.Row="1"
              Padding="8,0"
              Visibility="{x:Bind ViewModel.ShowFooter, Mode=OneWay}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  Connected + idle: Sync now.  -->
            <Button Grid.Column="0"
                    MinWidth="120"
                    HorizontalAlignment="Left"
                    Click="OnSyncNow"
                    Visibility="{x:Bind ViewModel.ShowSyncNowButton, Mode=OneWay}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE895;" FontSize="16" />
                    <TextBlock Text="{x:Bind ViewModel.SyncActionLabel, Mode=OneWay}" />
                </StackPanel>
            </Button>
            <StackPanel Grid.Column="0"
                        HorizontalAlignment="Left"
                        Orientation="Horizontal"
                        Spacing="4"
                        Visibility="{x:Bind ViewModel.ShowSyncControls, Mode=OneWay}">
                <Button Click="OnPauseSync">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE769;" FontSize="16" />
                        <TextBlock Text="Pause" />
                    </StackPanel>
                </Button>
                <Button Click="OnCancelSync"
                        Style="{StaticResource SubtleButtonStyle}"
                        ToolTipService.ToolTip="Stop and cancel this sync">
                    <TextBlock Text="Cancel" />
                </Button>
            </StackPanel>

            <!--  Empty state: status caption replacing Sync now.  -->
            <TextBlock Grid.Column="0"
                       Margin="8,0,0,0"
                       VerticalAlignment="Center"
                       Text="{x:Bind ViewModel.DisconnectedFooterText, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay}" />

            <!--  Right rail: Eject (connected only) + Settings (always).  -->
            <StackPanel Grid.Column="1"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Spacing="2">
                <Button Padding="10"
                        ToolTipService.ToolTip="Eject iPod"
                        Style="{StaticResource SubtleButtonStyle}"
                        BorderThickness="0"
                        Visibility="{x:Bind ViewModel.ShowConnectedContent, Mode=OneWay}">
                    <FontIcon Glyph="&#xF847;" FontSize="16" />
                </Button>
                <Button Padding="10"
                        Click="OnOpenSettings"
                        ToolTipService.ToolTip="Settings"
                        Style="{StaticResource SubtleButtonStyle}"
                        BorderThickness="0">
                    <FontIcon Glyph="&#xE713;" FontSize="16" />
                </Button>
            </StackPanel>
        </Grid>

        <!--
            Prompt overlay. Spans both rows so it covers the full
            popover (content + footer); placed last in document order
            so it wins z-order naturally. Visibility binds to
            PromptActive — when true, the connected / empty / footer
            layouts above are simultaneously hidden via their own
            ShowConnectedContent / ShowEmptyState / ShowFooter binds,
            so the overlay doesn't need an opaque background to mask
            them out. Rendered by the daemon ferrying a PromptEvent
            from the sync subprocess (source-change safeguard,
            per-track retry/skip/abort, etc.); button click sends
            DecidePromptCommand back via the daemon.
        -->
        <Grid Grid.Row="0"
              Grid.RowSpan="2"
              Padding="16"
              Visibility="{x:Bind ViewModel.PromptActive, Mode=OneWay}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <ScrollViewer Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <TextBlock Text="{x:Bind ViewModel.PromptMessage, Mode=OneWay}"
                           TextWrapping="Wrap"
                           Style="{StaticResource CaptionTextBlockStyle}" />
            </ScrollViewer>
            <ItemsControl Grid.Row="1"
                          Margin="0,8,0,0"
                          ItemsSource="{x:Bind ViewModel.PromptOptions, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" Spacing="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Button HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Content="{x:Bind}"
                                Click="OnPromptOptionClicked" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</Window>

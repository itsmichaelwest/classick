<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Classick_UI.Views.WizardFolderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Padding="24,16,24,0" Spacing="16">
        <TextBlock Text="Choose your music folder"
                   Style="{ThemeResource SubtitleTextBlockStyle}" />
        <TextBlock TextWrapping="Wrap"
                   MaxWidth="400"
                   HorizontalAlignment="Left"
                   Text="You can choose a folder that's local on your PC or on a network share. For network shares, it's recommended to use the full UNC path (e.g. \\server\share) rather than mapped drive letters." />
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <!-- PropertyChanged update trigger so Next re-evaluates on every keystroke. -->
            <TextBox Width="400"
                     Text="{Binding SourcePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="e.g. C:\Users\Name\Music" />
            <Button MinWidth="120"
                    Content="Browse…"
                    Click="OnBrowseClick" />
        </StackPanel>
    </StackPanel>
</Page>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Not sandboxed: the app spawns the classick daemon which needs raw
         device access and shares a $TMPDIR socket. Hardened runtime is on
         (required for notarization); library validation stays enabled because
         every bundled dylib + the daemon are signed with the same Team ID. -->
    <key>com.apple.security.cs.allow-jit</key>
    <false/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <false/>
</dict>
</plist>
